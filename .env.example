# 复制为 .env 后按需修改
PROXYHARBOR_AUTH_KEY=change-me

# === 接入已有 MySQL ===
# DSN 格式：user:pass@tcp(host:port)/db?parseTime=true&loc=UTC
PROXYHARBOR_MYSQL_DSN=proxyharbor:proxyharbor@tcp(host.docker.internal:3306)/proxyharbor?parseTime=true&loc=UTC

# === 接入已有 Redis（留空则关闭缓存）===
PROXYHARBOR_REDIS_ADDR=host.docker.internal:6379
PROXYHARBOR_REDIS_PASSWORD=
PROXYHARBOR_REDIS_DB=0

# === 其它可选 ===
PROXYHARBOR_ROLE=all
PROXYHARBOR_HOST_PORT=8080
PROXYHARBOR_CACHE_TTL=60s
PROXYHARBOR_GATEWAY_URL=http://localhost:8080
