# 将本文件复制为 `.env` 后再按环境修改。
# 不要把生产密码、节点地址、Token、Access Key 或任何密钥提交到版本库。
# 本文件只提供本地开发、容器联调和自测示例值。

# === 基础鉴权 ===
# 控制面 API 与网关校验使用的共享密钥。
# 生产环境必须改成高强度随机值，不能继续使用示例值。
PROXYHARBOR_TENANT_KEYS=default:changeme1234567890abcdef

# === 日志 ===
# 使用标准库 log/slog；生产建议 json，排障可临时切到 debug。
PROXYHARBOR_LOG_FORMAT=json
PROXYHARBOR_LOG_LEVEL=info

# === MySQL 存储 ===
# MySQL 是代理 catalog 与健康状态的权威数据源。
# DSN 格式：user:pass@tcp(host:port)/db?parseTime=true&loc=UTC
# 使用 docker compose bundle profile 时建议使用 mysql:3306。
# app 容器连接宿主机 MySQL 时可使用 host.docker.internal:3306。
PROXYHARBOR_MYSQL_DSN=proxyharbor:proxyharbor@tcp(mysql:3306)/proxyharbor?parseTime=true&loc=UTC

# === Redis 缓存与 zfair 调度 ===
# Redis 是 zfair selector 的调度状态来源，负责 ZSET ready/delayed 队列与 Lua 原子选择。
# selector=zfair 时 Redis 不应留空，否则服务会启动失败，避免调度状态不一致。
# 使用 docker compose bundle profile 时建议使用 redis:6379。
# app 容器连接宿主机 Redis 时可使用 host.docker.internal:6379。
PROXYHARBOR_REDIS_ADDR=redis:6379
PROXYHARBOR_REDIS_PASSWORD=
PROXYHARBOR_REDIS_DB=0
# Startup retries MySQL/Redis for about 30s, then fails fast instead of waiting forever.
# /readyz checks enabled dependencies live and returns 503 until they recover.

# === 进程与 HTTP ===
# role 可选值：all | controller | gateway
# all 表示同一进程同时运行控制面与网关。
PROXYHARBOR_ROLE=all
# 宿主机暴露端口；容器内监听端口仍为 8080。
PROXYHARBOR_HOST_PORT=8080
# Catalog / Lease 热路径缓存 TTL，示例：30s、60s、5m。
PROXYHARBOR_CACHE_TTL=60s
# Lease 返回给客户端使用的网关访问地址。
PROXYHARBOR_GATEWAY_URL=http://localhost:8080
# 默认禁止注册 loopback、内网、链路本地等代理 endpoint。
# 本地测试回环地址或内网代理时可设置为 true。
PROXYHARBOR_ALLOW_INTERNAL_PROXY_ENDPOINT=false

# === 代理选择算法与健康评分 ===
# 当前选择算法为 zfair。
# zfair = Redis ZSET + Lua + virtual_runtime 的公平调度器。
PROXYHARBOR_SELECTOR=zfair
# true 表示 selector=zfair 时强制要求 Redis 可用，避免多实例部署时调度行为不一致。
PROXYHARBOR_SELECTOR_REDIS_REQUIRED=true
# 健康评分策略：default | aggressive | lenient
# default 适合常规代理池；aggressive 更快降权/熔断；lenient 更保守。
PROXYHARBOR_SCORING_PROFILE=default
# 健康反馈本地聚合后批量写入 MySQL 的间隔。
PROXYHARBOR_HEALTH_FLUSH_INTERVAL=5s
# 健康反馈内存缓冲区上限；满时丢弃最旧事件以保护进程内存。
PROXYHARBOR_HEALTH_BUFFER_MAX=10000

# === zfair 调度参数 ===
# virtual_runtime 每次增长的基础量。
# 权重越高，单次增长越小，因此越容易再次被选中。
PROXYHARBOR_ZFAIR_QUANTUM=1000
# 代理没有 latency_ewma_ms 时使用的默认延迟，单位毫秒。
# 该值只影响缺失延迟数据的新代理或历史数据不完整代理。
PROXYHARBOR_ZFAIR_DEFAULT_LATENCY_MS=200
# 每次选择前最多从 delayed 队列提升回 ready 队列的代理数量。
# 值过小会导致冷却恢复不及时；值过大可能增加 Redis Lua 单次执行成本。
PROXYHARBOR_ZFAIR_MAX_PROMOTE=128

# === 主动健康检查 ===
# 留空表示关闭主动巡检，避免无意向第三方泄露代理出口 IP。
# 配置后系统会按 interval 周期访问该 URL 并记录成功率、延迟和失败原因。
PROXYHARBOR_HEALTHCHECK_URL=
PROXYHARBOR_HEALTHCHECK_INTERVAL=30s
PROXYHARBOR_HEALTHCHECK_TIMEOUT=5s

# === 会话粘性预留 ===
# 当前只保留配置与接口，不实现 sticky mapping 读写。
PROXYHARBOR_STICKY_ENABLED=false
PROXYHARBOR_STICKY_POLICY=none

